# Claude Code local settings — machine-specific, never commit
.claude/settings.local.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment files — never commit secrets
.env
.env.local
.env.*.local
*.env

# Exception: sample-target/.env is a DELIBERATE FAKE fixture (no real secrets) so the
# guardian has a real on-disk secret file to block reads against. Keep it tracked.
!sample-target/.env

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Build artifacts
dist/
build/
out/

# arXiv source bundle(s) — regenerated from paper/ (main.tex + refs.bib + figures); rebuild, don't commit
paper_submission.zip
paper/*.zip

# Editor
.vscode/settings.json
.idea/
*.suo
*.user

# Databases — Headroom uses SQLite; never commit local data or LangGraph checkpoints
*.db
*.db-wal
*.db-shm
*.db-journal
*.sqlite
*.sqlite3

# Generated eval artifacts. The PNGs, calibration.json, noise_floor.json and
# model_comparison.json are COMMITTED so the cited numbers (κ, per-model AURCs) and the
# dashboard dial ship without an API key. The rest regenerate key-free or near-free.
eval/inverted_u.json
eval/fatigue_attack.json
eval/nseed.json

# Internal working notes — kept local, not for the public repo. Preserved on the
# archive/internal-notes-* branch and in history; ignored here so they aren't re-added.
docs/PAPER.md
docs/DECISIONS.md
