# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# Anthropic API key — powers the worker agent and the guardian's LLM judge call.
# Required for real runs (uvicorn / demo) and the eval. Tests use a fake worker and do NOT need it.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# LangSmith tracing (optional but recommended — backs the observability story).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=headroom

# Human-approval timeout (milliseconds). Pending actions past this expire to "deny" (fail-safe).
APPROVAL_TTL_MS=120000

# Server port for the FastAPI dashboard.
PORT=8000
